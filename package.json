{
  "name": "pi-extension-unstoppable",
  "version": "1.0.0",
  "description": "pi extension for auto-continuation and rest tool",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
